{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "maybelucas",
  // Update to today's date
  "compatibility_date": "2025-03-25",
  "assets": {
    "directory": "./dist"
  },
  "observability": {
    "enabled": true
  },
  "routes": [
    {
      "pattern": "maybelucas.com",
      "custom_domain": true
    },
    {
      "pattern": "lucasbarbosa.net",
      "custom_domain": true
    },
    {
      "pattern": "lbxa.net",
      "custom_domain": true
    },
  ]
}
