---
import ContentLayout from "@layouts/ContentLayout.astro";
import { getEntry, render } from "astro:content";

const bookshelfPage = await getEntry("bookshelf", "index");
if (!bookshelfPage) {
  throw new Error("Bookshelf content not found");
}
const { Content: BookshelfContent } = await render(bookshelfPage);
---

<ContentLayout title="Bookshelf">
  <section class="blog-content content mb-xl">
    <h1>Bookshelf</h1>
    <BookshelfContent />
  </section>
</ContentLayout>
