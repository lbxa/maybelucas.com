---
import { getCollection } from "astro:content";
import dayjs from "dayjs";
import ContentLayout from "@layouts/ContentLayout.astro";
import ReadingTime from "@components/ReadingTime.astro";

const pageTitle = "All my writing";
const pageDescription =
  "Browse the full archive of my writing, sorted by recency with reading times.";
// Keep canonicalPath per page (e.g., /posts/page/2) if pagination/filters are added.
const canonicalPath = "/posts";
const dateFormat = "D MMM";

const posts = (await getCollection("blog")).sort((a, b) =>
  dayjs(a.data.date).isBefore(dayjs(b.data.date)) ? 1 : -1,
);

const postsByYear = posts.reduce(
  (groups, post) => {
    const year = dayjs(post.data.date).format("YYYY");
    const currentGroup = groups.at(-1);

    if (currentGroup?.year === year) {
      currentGroup.posts.push(post);
      return groups;
    }

    groups.push({ year, posts: [post] });
    return groups;
  },
  [] as Array<{ year: string; posts: typeof posts }>,
);
---

<ContentLayout
  title={pageTitle}
  description={pageDescription}
  url={canonicalPath}
  type="website"
>
  <!-- <section class="font-mono">
    <Title>Posts</Title>
    <p class="mb-3xl">Toward escape velocity</p>
  </section> -->
  <section class="flex flex-col gap-2xl">
    {
      postsByYear.map(({ year, posts }) => (
        <section aria-labelledby={`posts-${year}`}>
          <h2
            id={`posts-${year}`}
            class="!mt-0 !mb-lg font-mono !text-xs !leading-snug font-medium tracking-normal text-gray-600 dark:text-gray-400"
          >
            {year}
          </h2>
          {posts.map((p) => (
            <article class="mb-xl grid grid-cols-[minmax(0,1fr)_auto] gap-x-md gap-y-xs sm:gap-x-lg">
              <a
                class="col-start-1 row-start-1 min-w-0 truncate no-underline hover:underline focus:underline visited:text-blue-700 dark:visited:text-blue-300"
                href={"/posts/" + p.id}
              >
                {p.data.title.trim()}
              </a>
              <div class="col-start-2 row-start-1 whitespace-nowrap text-right text-xs leading-snug text-gray-700 dark:text-gray-400">
                <span>{dayjs(p.data.date).format(dateFormat)}</span>
              </div>
              <p class="col-start-1 row-start-2 !mb-0 min-w-0 truncate text-sm leading-snug text-gray-600 dark:text-gray-400">
                {p.data.description.trim()}
              </p>
              <div class="col-start-2 row-start-2 whitespace-nowrap text-right text-xs leading-snug text-gray-700 dark:text-gray-400">
                <ReadingTime content={p.body ?? ""} />
              </div>
            </article>
          ))}
        </section>
      ))
    }
  </section>
</ContentLayout>
