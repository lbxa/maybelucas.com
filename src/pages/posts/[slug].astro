---
import { getCollection, getEntry, render } from "astro:content";
import ContentLayout from "@layouts/ContentLayout.astro";
import dayjs from "dayjs";
import Title from "@components/Title.astro";
import ReadingTime from "@/components/ReadingTime.astro";
import WordCount from "@/components/WordCount.astro";

const { slug } = Astro.params;
if (!slug) {
  throw new Error("Missing blog slug parameter");
}

const entry = await getEntry("blog", slug);

// TODO Redirect to 404 page
if (!entry) {
  throw new Error(`Blog post with slug "${slug}" not found`);
}

const { Content } = await render(entry);
const publishedDate = entry.data.date;
const modifiedDate =
  (entry.data as { updated?: Date }).updated ?? publishedDate;
const opener = entry.data.description?.trim();
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const dateFormat = "MMMM D, YYYY";

const jsonLd = JSON.stringify(
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: entry.data.title,
    description: entry.data.description,
    author: {
      "@type": "Person",
      name: entry.data.author,
    },
    datePublished: publishedDate.toISOString(),
    dateModified: modifiedDate.toISOString(),
    url: canonicalUrl.toString(),
  },
  null,
  2
);

// Define getStaticPaths to generate paths for all blog posts
export async function getStaticPaths() {
  const blogPosts = await getCollection("blog");
  return blogPosts.map((post) => ({
    params: { slug: post.id },
  }));
}
---

<ContentLayout
  title={entry.data.title}
  description={entry.data.description ?? undefined}
  url={`/posts/${entry.id}`}
  publishedTime={entry.data.date.toISOString?.()}
  type="article"
>
  <header class="mb-2xl">
    <div class="my-lg">
      <a
        href="/posts"
        class="font-mono text-xs hover:underline no-underline inline-flex items-center gap-xs text-gray-700 dark:text-gray-400 hover:text-shark-950 hover:dark:text-ivory transition-colors duration-200"
      >
        ← Go back
      </a>
    </div>
    <Title>{entry.data.title}</Title>
    <div class="font-mono text-xs text-gray-700 dark:text-gray-400 flex flex-wrap items-center gap-x-sm">
      <WordCount content={entry.body ?? ""} />
      <span>•</span>
      <ReadingTime content={entry.body ?? ""} />
      <span>•</span>
      <span>Written {dayjs(entry.data.date).format(dateFormat)}</span>
    </div>
  </header>
  <script type="application/ld+json" is:inline>{jsonLd}</script>
  <section class="mx-auto">
    {
      opener && (
        <p class="mb-2xl border-l-2 border-shark-950/20 pl-md font-serif text-[1.35rem] leading-relaxed text-shark-700 dark:border-ivory/25 dark:text-shark-200 md:text-[1.55rem]">
          {opener}
        </p>
      )
    }
    <div
      class="blog-content content [&_p]:text-[1.125rem] md:[&_p]:text-[1.25rem] [&_p]:leading-[1.85] [&_li]:text-[1.0625rem] md:[&_li]:text-[1.125rem] [&_li]:leading-[1.8]"
    >
      <Content />
    </div>
  </section>
</ContentLayout>
