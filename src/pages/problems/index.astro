---
import { getCollection } from "astro:content";
import dayjs from "dayjs";
import ContentLayout from "@layouts/ContentLayout.astro";

const pageTitle = "Problems of the Day";
const pageDescription =
  "Browse Lucas Barbosa's problems of the day and solution notes.";
const canonicalPath = "/problems";
const dateFormat = "D MMM";

const problems = (await getCollection("problems")).sort((a, b) =>
  dayjs(a.data.date).isBefore(dayjs(b.data.date)) ? 1 : -1,
);

const problemsByYear = problems.reduce(
  (groups, problem) => {
    const year = dayjs(problem.data.date).format("YYYY");
    const currentGroup = groups.at(-1);

    if (currentGroup?.year === year) {
      currentGroup.problems.push(problem);
      return groups;
    }

    groups.push({ year, problems: [problem] });
    return groups;
  },
  [] as Array<{ year: string; problems: typeof problems }>,
);
---

<ContentLayout
  title={pageTitle}
  description={pageDescription}
  url={canonicalPath}
  type="website"
>
  <section class="flex flex-col gap-2xl">
    {
      problemsByYear.length > 0 ? (
        problemsByYear.map(({ year, problems }) => (
          <section aria-labelledby={`problems-${year}`}>
            <h2
              id={`problems-${year}`}
              class="!mt-0 !mb-lg font-mono !text-xs !leading-snug font-medium tracking-normal text-gray-600 dark:text-gray-400"
            >
              {year}
            </h2>
            {problems.map((problem) => (
              <article class="mb-xl grid grid-cols-[minmax(0,1fr)_auto] gap-x-md gap-y-xs sm:gap-x-lg">
                <a
                  class="col-start-1 row-start-1 min-w-0 truncate no-underline hover:underline focus:underline visited:text-blue-700 dark:visited:text-blue-300"
                  href={"/problems/" + problem.id}
                >
                  {problem.data.title.trim()}
                </a>
                <div class="col-start-2 row-start-1 whitespace-nowrap text-right text-xs leading-snug text-gray-700 dark:text-gray-400">
                  <span>{dayjs(problem.data.date).format(dateFormat)}</span>
                </div>
                <p class="col-start-1 row-start-2 !mb-0 min-w-0 truncate text-sm leading-snug text-gray-600 dark:text-gray-400">
                  {problem.data.description.trim()}
                </p>
                <div class="col-start-2 row-start-2 whitespace-nowrap text-right text-xs leading-snug text-gray-700 dark:text-gray-400">
                  <span>
                    {problem.data.difficulty}/10 &middot;{" "}
                    {problem.data.estimatedTime} min
                  </span>
                </div>
                <p class="col-start-1 row-start-3 !mb-0 min-w-0 truncate font-mono text-xs leading-snug text-gray-600 dark:text-gray-400">
                  {problem.data.topic.trim()}
                </p>
              </article>
            ))}
          </section>
        ))
      ) : (
        <p class="!mb-0 text-sm leading-snug text-gray-600 dark:text-gray-400">
          No problems yet.
        </p>
      )
    }
  </section>
</ContentLayout>
