---
import Socials from "@components/Socials.astro";
import ContentLayout from "@layouts/ContentLayout.astro";
import Image from "@components/Image.astro";
import { getEntry, render } from "astro:content";
import profileImage from "../assets/images/profile.webp";
import treeImage from "../assets/images/tree.webp";

const bioIntro = await getEntry("about", "bio-intro");
if (!bioIntro) {
  throw new Error("Bio intro content not found");
}
const { Content: BioIntroContent } = await render(bioIntro);

const publications = await getEntry("about", "publications");
if (!publications) {
  throw new Error("Publications content not found");
}
const { Content: PublicationsContent } = await render(publications);

---

<ContentLayout
  title="Lucas Barbosa"
  ogTitle="Lucas Barbosa - Software, AI, and Life"
  ogDescription="Thoughtful essays on software engineering, AI, startups, and personal growth. Explore ideas, practical lessons, and experiments."
  url="/"
  type="profile"
>
  <div class="mt-md mb-xl w-32 sm:w-38 md:w-44">
    <Image
      src={profileImage}
      alt="Portrait photo"
      width={176}
      height={176}
      class="!my-0 w-full"
      thumbhash="5b180e1704cf97679d97876887c7678667769740460a6404"
      loading="eager"
      fetchpriority="high"
      quality={70}
    />
  </div>
  <section class="blog-content content mb-xl">
    <BioIntroContent />
  </section>
  <section class="mb-3xl">
    <Socials />
  </section>
  <!-- <section class="blog-content content mb-xl">
    <h2>Publications</h2>
    <PublicationsContent />
  </section> -->
  <!-- <Image
    src={treeImage}
    alt="Sunset shining through a bamboo grove"
