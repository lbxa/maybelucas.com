---
import Socials from "@components/Socials.astro";
import MobiusStrip from "@components/MobiusStrip/MobiusStrip.astro";
import ContentLayout from "@layouts/ContentLayout.astro";
import { Image } from "astro:assets";
import { getEntry } from "astro:content";
import profileImage from "../assets/images/profile.webp";

const bio = await getEntry("about", "bio");
if (!bio) {
  throw new Error("Bio content not found");
}
const { Content: BioContent } = await bio.render();

const manifesto = await getEntry("about", "manifesto");
if (!manifesto) {
  throw new Error("Manifesto content not found");
}
const { Content: ManifestoContent } = await manifesto.render();
---

<ContentLayout
  title="Lucas Barbosa"
  description="Personal website and blog of Lucas Barbosa."
  url="/"
  type="profile"
>
  <div class="mb-xl w-28 sm:w-36 md:w-44">
    <Image
      src={profileImage}
      alt="Portrait photo"
      width={176}
      height={176}
      loading="eager"
      fetchpriority="high"
      quality={70}
    />
  </div>
  <Socials />
  <section class="blog-content mb-3xl content">
    <BioContent />
  </section>
  <MobiusStrip slot="background" />
</ContentLayout>
