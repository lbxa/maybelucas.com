---
import { Image as AstroImage } from "astro:assets";
import { thumbhashHexToDataUrl } from "../lib/thumbhashPlaceholder";

type ImageLike = string | { src: string; width?: number; height?: number };

interface Props {
  src: ImageLike;
  alt: string;
  caption?: string;
  captionSourceHref?: string;
  captionSourceLabel?: string;
  width?: number;
  height?: number;
  class?: string;
  /** ThumbHash as hex from `bun run gen-thumbhash <image-path>` — decoded at build time */
  thumbhash?: string;
  loading?: "eager" | "lazy";
  decoding?: "async" | "auto" | "sync";
  fetchpriority?: "high" | "low" | "auto";
  quality?: number;
  layout?: "constrained" | "fixed" | "full-width" | "none";
  widths?: number[];
  sizes?: string;
}

const {
  src,
  alt,
  caption,
  captionSourceHref,
  captionSourceLabel,
  width,
  height,
  class: className,
  thumbhash,
  loading,
  decoding,
  fetchpriority,
  quality,
  layout,
  widths,
  sizes,
} = Astro.props as Props;
const isOptimizable = typeof src === "object" && src !== null && "src" in src;
const captionSourceLabelText = captionSourceLabel ?? "Source";
const viewerCaptionSourceLabel = captionSourceHref
  ? captionSourceLabelText
  : undefined;

const placeholderDataUrl = thumbhash
  ? thumbhashHexToDataUrl(thumbhash)
  : undefined;

const placeholderFigureId = thumbhash ? `ph-${crypto.randomUUID()}` : undefined;

const aspectStyle =
  thumbhash && width != null && height != null
    ? `aspect-ratio: ${width} / ${height}`
    : undefined;

const interactiveMainImageClass =
  "cursor-zoom-in outline-none transition-transform duration-200 hover:scale-[1.01] focus-visible:ring-2 focus-visible:ring-shark-700/60 focus-visible:ring-offset-2 focus-visible:ring-offset-ivory dark:focus-visible:ring-ivory/60 dark:focus-visible:ring-offset-shark-950";

const mainImgClass = thumbhash
  ? `relative z-10 h-auto w-full opacity-0 transition-opacity duration-500 ${interactiveMainImageClass}`
  : interactiveMainImageClass;

const mainOnLoad = thumbhash
  ? [
      "this.classList.add('opacity-100')",
      "this.closest('figure')?.classList.add('thumbhash-loaded')",
    ].join("; ")
  : undefined;
---

<figure
  class:list={[
    "not-prose my-6",
    thumbhash && "thumbhash-placeholder",
    className,
  ]}
  id={placeholderFigureId}
>
  {
    thumbhash ? (
      <div
        class="placeholder-shell relative w-full overflow-hidden rounded-lg"
        style={aspectStyle}
      >
        <img
          src={placeholderDataUrl}
          alt=""
          width={width}
          height={height}
          class="pointer-events-none absolute inset-0 z-0 h-full w-full object-cover"
          aria-hidden="true"
        />
        {isOptimizable ? (
          <AstroImage
            src={src as any}
            alt={alt}
            width={width}
            height={height}
            class={mainImgClass}
            data-main-image
            data-image-viewer-trigger="true"
            data-image-viewer-alt={alt}
            data-image-viewer-caption={caption}
            data-image-viewer-caption-source-href={captionSourceHref}
            data-image-viewer-caption-source-label={viewerCaptionSourceLabel}
            tabindex="0"
            aria-haspopup="dialog"
            onload={mainOnLoad}
            loading={loading}
            decoding={decoding}
            fetchpriority={fetchpriority}
            quality={quality}
            layout={layout}
            widths={widths}
            sizes={sizes}
          />
        ) : (
          <img
            src={src as string}
            alt={alt}
            width={width}
            height={height}
            loading="lazy"
            decoding="async"
            class={mainImgClass}
            data-main-image
            data-image-viewer-trigger="true"
            data-image-viewer-alt={alt}
            data-image-viewer-caption={caption}
            data-image-viewer-caption-source-href={captionSourceHref}
            data-image-viewer-caption-source-label={viewerCaptionSourceLabel}
            tabindex="0"
            aria-haspopup="dialog"
            onload={mainOnLoad}
          />
        )}
      </div>
    ) : isOptimizable ? (
      <AstroImage
        src={src as any}
        alt={alt}
        width={width}
        height={height}
        class={mainImgClass}
        data-image-viewer-trigger="true"
        data-image-viewer-alt={alt}
        data-image-viewer-caption={caption}
        data-image-viewer-caption-source-href={captionSourceHref}
        data-image-viewer-caption-source-label={viewerCaptionSourceLabel}
        tabindex="0"
        aria-haspopup="dialog"
        loading={loading}
        decoding={decoding}
        fetchpriority={fetchpriority}
        quality={quality}
        layout={layout}
        widths={widths}
        sizes={sizes}
      />
    ) : (
      <img
        src={src as string}
        alt={alt}
        width={width}
        height={height}
        loading="lazy"
        decoding="async"
        class={mainImgClass}
        data-image-viewer-trigger="true"
        data-image-viewer-alt={alt}
        data-image-viewer-caption={caption}
        data-image-viewer-caption-source-href={captionSourceHref}
        data-image-viewer-caption-source-label={viewerCaptionSourceLabel}
        tabindex="0"
        aria-haspopup="dialog"
      />
    )
  }
  {
    (caption || captionSourceHref) && (
      <figcaption class="mt-2 text-center text-sm text-gray-500 dark:text-gray-400">
        {caption}
        {caption && captionSourceHref && " "}
        {captionSourceHref && (
          <a href={captionSourceHref} target="_blank" rel="noreferrer">
            {captionSourceLabelText}
          </a>
        )}
      </figcaption>
    )
  }
  {
    thumbhash && placeholderFigureId && (
      <script is:inline define:vars={{ placeholderFigureId }}>
        requestAnimationFrame(() => {
          const root = document.getElementById(placeholderFigureId);
          const img = root?.querySelector("[data-main-image]");
          if (img instanceof HTMLImageElement && img.complete) {
            img.classList.add("opacity-100");
            root?.classList.add("thumbhash-loaded");
          }
        });
      </script>
    )
  }
</figure>

<style>
  figure:not(.thumbhash-placeholder) :where(img) {
    display: block;
    margin-left: auto;
    margin-right: auto;
    border-radius: 0.5rem;
  }

  figure.thumbhash-placeholder .placeholder-shell :where(img:not([aria-hidden="true"])) {
    display: block;
    margin-left: auto;
    margin-right: auto;
  }

  figure.thumbhash-placeholder .placeholder-shell :where(img[aria-hidden="true"]) {
    transition: opacity 500ms ease;
  }

  figure.thumbhash-placeholder.thumbhash-loaded .placeholder-shell :where(img[aria-hidden="true"]) {
    opacity: 0;
  }
</style>
