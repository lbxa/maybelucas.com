---
interface Props {
  summary?: string;
  open?: boolean;
}

const { summary, open = false } = Astro.props;
---

<details class="toggle" open={open}>
  <summary class="flex cursor-pointer select-none items-start gap-sm mb-lg">
    <svg
      viewBox="0 0 10 10"
      width="14"
      height="14"
      aria-hidden="true"
      focusable="false"
      class="toggle-marker text-shark-500 dark:text-shark-400 mt-[0.22em] shrink-0"
    >
      <path d="M 3.5 2 L 7.5 5 L 3.5 8 Z" fill="currentColor"></path>
    </svg>
    <span class="toggle-summary-text min-w-0 flex-1 leading-snug">
      <slot name="summary">{summary}</slot>
    </span>
  </summary>
  <div class="toggle-content ml-xl mt-sm">
    <slot />
  </div>
</details>

<style>
  .toggle[open] {
    position: relative;
    z-index: 80;
    isolation: isolate;
  }

  .toggle > summary {
    list-style: none;
  }
  .toggle > summary::-webkit-details-marker {
    display: none;
  }

  .toggle-marker {
    transform-origin: center;
    transition: transform 200ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .toggle[open] > summary .toggle-marker {
    transform: rotate(90deg);
  }

  .toggle[open]::before {
    content: "";
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background: rgb(18 18 18 / 0.62);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    animation: toggle-overlay-fade 220ms ease-out;
  }

  :global(.dark) .toggle[open]::before {
    background: rgb(18 18 18 / 0.72);
  }

  .toggle[open] > summary,
  .toggle[open] > .toggle-content {
    position: relative;
    z-index: 1;
  }

  .toggle[open] > .toggle-content {
    animation: toggle-fade 220ms ease-out;
    border-radius: 0.875rem;
    border: 1px solid rgb(18 18 18 / 0.14);
    background: rgb(245 245 245 / 0.87);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    box-shadow: 0 26px 56px -34px rgb(18 18 18 / 0.9);
    padding: 0.875rem 1rem;
  }

  :global(.dark) .toggle[open] > .toggle-content {
    border-color: rgb(245 245 245 / 0.16);
    background: rgb(18 18 18 / 0.84);
    box-shadow: 0 24px 56px -36px rgb(0 0 0 / 1);
  }

  @keyframes toggle-overlay-fade {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes toggle-fade {
    from {
      opacity: 0;
      transform: translateY(-2px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .toggle-marker {
      transition: none;
    }
    .toggle[open]::before {
      animation: none;
    }
    .toggle[open] > .toggle-content {
      animation: none;
    }
  }
</style>
