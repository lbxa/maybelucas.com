---
import { MobiusStripRenderer } from "@/components/MobiusStrip/MobiusStripRenderer";
---

<canvas id="webgl"></canvas>
<MobiusStripRenderer client:idle />

<style>
  canvas#webgl {
    position: fixed;
    top: 0;
    left: 0;
    outline: none;
    width: 100%;
    height: 100%;
    z-index: 1;
    pointer-events: none;
  }
</style>
